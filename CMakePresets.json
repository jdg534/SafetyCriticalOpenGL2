{
  "version": 5,
  "cmakeMinimumRequired":
  {
    "major": 3,
    "minor": 21
  },
  "configurePresets":
  [
	{
		"name": "windows-static",
		"displayName": "Windows (x64 static)",
		"description": "Build using vcpkg static triplet on Windows",
		"generator": "Visual Studio 17 2022",
		"binaryDir": "${sourceDir}/build",
		"cacheVariables":
		{
			"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/submodules/vcpkg/scripts/buildsystems/vcpkg.cmake",
			"VCPKG_TARGET_TRIPLET": "x64-windows-static",
			"CMAKE_BUILD_TYPE": "Debug",
			"CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebug"
		}
	},
	{
		"name": "static-analysis",
		"displayName": "Linux x64",
		"description": "Build target to generate a compile_commands.json",
		"generator": "Unix Makefiles",
		"binaryDir": "${sourceDir}/static_analysis",
		"cacheVariables": 
		{
			"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/submodules/vcpkg/scripts/buildsystems/vcpkg.cmake",
			"VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic",
			"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
		}
	}
  ]
}